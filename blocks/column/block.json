{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ahlfeld-solutions/column",
  "title": "Column",
  "description": "Bootstrap column with configurable widths at every breakpoint.",
  "category": "ahlfeld-solutions",
  "icon": "align-pull-left",
  "keywords": ["column", "col", "grid", "layout"],
  "supports": {
    "anchor": true,
    "html": false
  },
  "attributes": {
    "colXs":       { "type": "string", "default": "col" },
    "colSm":       { "type": "string", "default": "" },
    "colMd":       { "type": "string", "default": "" },
    "colLg":       { "type": "string", "default": "" },
    "colXl":       { "type": "string", "default": "" },
    "offsetMd":    { "type": "string", "default": "" },
    "offsetLg":    { "type": "string", "default": "" },
    "alignSelf":   { "type": "string", "default": "" }
  },
  "render": "file:./render.php",
  "editorScript": "file:../../assets/dist/blocks/column/index.js"
}
